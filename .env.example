# --- Uptime Kuma connection ---
KUMA_SERVER=http://uptime-kuma:3001
KUMA_USERNAME=changeme
# Use a Kuma user WITHOUT 2FA (2FA not supported in v1)
KUMA_PASSWORD=changeme

# --- Client auth ---
# Comma-separated strong random keys. Generate e.g.: python -c "import secrets;print(secrets.token_urlsafe(32))"
# WARNING: an API key grants full monitor create/edit/delete rights.
API_KEYS=replace-with-strong-random-key

# --- Tuning (optional) ---
RATE_LIMIT=120/minute
# Set to your reverse-proxy IP(s) so X-Forwarded-For is trusted (rate-limit client IP)
FORWARDED_ALLOW_IPS=127.0.0.1
# CONNECT_TIMEOUT=10
# LOGIN_TIMEOUT=15
# LOCK_ACQUIRE_TIMEOUT=5
# CALL_TIMEOUT=30
# MUTATION_TIMEOUT=60
